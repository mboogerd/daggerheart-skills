{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pass",
    "score",
    "summary",
    "strengths",
    "issues",
    "confidence"
  ],
  "properties": {
    "pass": {
      "type": "boolean"
    },
    "score": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "strengths": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 5
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 5
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  }
}
